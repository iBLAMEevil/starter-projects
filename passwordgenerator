import random
import string

length = int(input("How many characters would you like this password to be?: "))
specialChar = input("Would you like special characters included in this password?: ").lower()
numberChar = input("Would you like numbers included in the password?: ").lower()
upperLower = input("Would you like to mix upper and lowercase?: ").lower()

def MakePassword(length,specialChar,numberChar,upperLower):
    finalPass = ("") #empty variable, but it wont be due to the script
    characters = string.ascii_lowercase #the characters that will be picked, are by default lowercase letters
    if specialChar == "yes" or specialChar == "y":
        characters += string.punctuation #if yes, include special characters
    if numberChar == "yes" or numberChar == "y":
        characters += string.digits #if yes, include digits
    if upperLower == "yes" or upperLower == "y":
        characters += string.ascii_uppercase #if yes, include uppercase
    for i in range(length): #for every integer in the length, in other words, however long the length is........
        finalPass += random.choice(characters) #repeat this x amount of times. This makes a random choice of letter in the character pool to the empty variable finalPass
    return(finalPass)#then, pass the result so it can be used OUTSIDE OF THE FUNCTION.

finalPass = MakePassword(length, specialChar, numberChar, upperLower) #call the function
print(finalPass)#print the result
print("Here is your final password, it consists of", length, "letters!") 