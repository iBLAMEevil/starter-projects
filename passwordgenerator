import random
import string

length = int(input("How many characters would you like this password to be?: "))
specialChar = input("Would you like special characters included in this password?: ").lower()
numberChar = input("Would you like numbers included in the password?: ").lower()
upperLower = input("Would you like to mix upper and lowercase?: ").lower()

def MakePassword(length,specialChar,numberChar,upperLower):
    finalPass = ("")
    characters = string.ascii_lowercase
    if specialChar == "yes" or specialChar == "y":
        characters += string.punctuation
    if numberChar == "yes" or numberChar == "y":
        characters += string.digits
    if upperLower == "yes" or upperLower == "y":
        characters += string.ascii_uppercase
    for i in range(length):
        finalPass += random.choice(characters)
    return(finalPass)

finalPass = MakePassword(length, specialChar, numberChar, upperLower)
print(finalPass)
print("Here is your final password, it consists of", length, "letters!")