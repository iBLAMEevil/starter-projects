
word = input("What word are you altering?: ")
shift = int(input("How many spaces would you like to shift?: "))

def ceaserShift(word, shift):
    newWord =("") #empty variable, but it wont be due to the script
    for letter in word: #for every letter in the word...
        if letter.isalpha(): #if the letter is alphabetical....
            if letter.islower(): #if the letter is lowercase...
                position = ord(letter) - 97
                newPos = (position + shift) % 26
                newWord += chr(newPos + 97) 
            elif letter.isupper(): #if the letter is uppercase...
                position = ord(letter) - 65
                newPos = (position + shift) % 26
                newWord += chr(newPos + 65)
        else: #anything else... (numbers mainly)
            position = ord(letter) - 48
            newPos = (position + shift) % 10
            newWord += chr(newPos + 48)
    return newWord #return the final result so IT CAN BE USED OUTSIDE OF THE FUNCTION.
newWord = ceaserShift(word, shift) #call the function
print(newWord)  #print the result
print("Here is your final cipher shifted" , shift, "characters")